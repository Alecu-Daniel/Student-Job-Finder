@model List<(Student_Job_Finder.Models.JobPost Job, decimal Similarity)>

@{
    ViewData["Title"] = "Matched Jobs";
}

<h2>Job Matches</h2>

@if (!Model.Any())
{
    <p>No jobs found for your skills.</p>
}
else
{
    <div class="matched-jobs-list">
        @foreach (var result in Model)
        {
            <div class="job-post-card">
                <h3>
                    <a href="/JobPost/PostSingle/@result.Job.PostId">
                        @result.Job.PostTitle
                    </a>
                </h3>
                <p>@result.Job.PostContent</p>
                <p>@result.Job.Price € / @result.Job.PricePeriod</p>
                <p>
                    <small>
                        Created: @result.Job.PostCreated.ToString("dd MMM yyyy") |
                        Updated: @result.Job.PostUpdated.ToString("dd MMM yyyy")
                    </small>
                </p>
                <p><strong>Match Score:</strong> @((result.Similarity * 100).ToString("0.##"))%</p>
            </div>
        }
    </div>
}

<style>
    .matched-jobs-list {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
        gap: 1rem;
        margin-top: 1rem;
    }

    .job-post-card {
        border: 1px solid #ccc;
        border-radius: 8px;
        padding: 1rem;
        background-color: #f9f9f9;
        box-shadow: 0 2px 6px rgba(0,0,0,0.05);
    }

    .job-post-card h3 {
        margin-top: 0;
    }

    .job-post-card p {
        margin: 0.5rem 0;
    }

    .job-post-card a {
        color: #007bff;
        text-decoration: none;
    }

    .job-post-card a:hover {
        text-decoration: underline;
    }
</style>
