@model List<Student_Job_Finder.Models.JobApplicationViewModel>

@using Student_Job_Finder.Helpers
@using Student_Job_Finder.Models

<p class="applications-view-title">Job Applications</p>

@if (!Model.Any())
{
    <p class="applications-view-title">No applications yet for this job post.</p>
}
else
{
    <div class="applications-list">
        @foreach (var app in Model)
        {
            <div class="application-card">

                <div class="application-card-header">
                    <div class="application-student-info-container">
                        <p class="application-student-name">@app.FirstName @app.LastName</p>
                        <p class="application-email">@app.Email</p>
                    </div>
                    <div class="application-match-container">
                        <span class="application-match-label">Match Score:</span>
                        <span class="application-match-score">@app.MatchScore.ToString("0.##")%</span>
                    </div>
                </div>

                <div class="application-skills-legend">
                    <div class="application-legend-item">
                        <ion-icon name="arrow-up-outline" class="application-greater-icon"></ion-icon>
                        <span>Overqualified</span>
                    </div>
                    <div class="application-legend-item">
                        <ion-icon name="reorder-two-outline" class="application-equal-icon"></ion-icon>
                        <span>Matches Requirement</span>
                    </div>
                    <div class="application-legend-item">
                        <ion-icon name="arrow-down-outline" class="application-less-icon"></ion-icon>
                        <span>Underqualified</span>
                    </div>
                    <div class="application-legend-item">
                        <ion-icon name="add-outline" class="application-extra-icon"></ion-icon>
                        <span>Additional Skill</span>
                    </div>
                </div>
                
                @if (app.StudentSkills.Any())
                {
                    <ul class="application-skills-list">
                        @{
                            var requiredSkillNames = app.RequiredSkills.Select(r => r.SkillName).ToList();

                            var requiredStudentSkills = app.StudentSkills
                            .Where(s => requiredSkillNames.Contains(s.SkillName))
                            .OrderBy(s => s.SkillName);

                            var additionalStudentSkills = app.StudentSkills
                            .Where(s => !requiredSkillNames.Contains(s.SkillName))
                            .OrderBy(s => s.SkillName);

                            var sortedSkills = requiredStudentSkills.Concat(additionalStudentSkills).ToList();
                            
                            bool dividerPlaced = false;
                        }

                        <li class="application-skill-column-label">Skill Names</li>
                        <li class="application-skill-column-label">Student Skills</li>
                        <li class="application-skill-column-label">Quiz Skills</li>
                        <li class="application-skill-column-label"></li>


                        @foreach (var skill in sortedSkills)
                        {

                            @if (!dividerPlaced && !requiredSkillNames.Contains(skill.SkillName) && requiredStudentSkills.Any())
                            {
                                <li class="skill-list-divider">
                                    <span>Additional Skills</span>
                                </li>
                                dividerPlaced = true;
                            }


                            <li class="application-skill-item">
                                <span class="application-skill-name">
                                    @skill.SkillName
                                </span>

                                <span class="application-skill-level @SkillHelper.SkillColorClass(skill.SkillScore)">
                                    @SkillHelper.SkillLevelName(skill.SkillScore)
                                </span>

                                @{
                                    var quizMatch = app.QuizResults?.FirstOrDefault(q => q.SkillName == skill.SkillName);
                                }
                                <span class="application-skill-level @(quizMatch != null ? SkillHelper.SkillColorClass(quizMatch.SkillScore) : null)">
                                    @(quizMatch != null ? SkillHelper.SkillLevelName(quizMatch.SkillScore) : "N/A")
                                </span>


                                @{
                                    var matchingRequirement = app.RequiredSkills
                                    .FirstOrDefault(r => r.SkillName.Equals(skill.SkillName));

                                    decimal evaluatedScore = quizMatch?.SkillScore ?? skill.SkillScore;
                                }

                                @if (matchingRequirement != null)
                                {
                                    @if (SkillHelper.GetSkillLevel(evaluatedScore) < SkillHelper.GetSkillLevel(matchingRequirement.SkillScore))
                                    {
                                        <ion-icon name="arrow-down-outline" class="application-less-icon"></ion-icon>
                                    }
                                    else if (SkillHelper.GetSkillLevel(evaluatedScore) == SkillHelper.GetSkillLevel(matchingRequirement.SkillScore))
                                    {
                                        <ion-icon name="reorder-two-outline" class="application-equal-icon"></ion-icon>
                                    }
                                    else
                                    {
                                        <ion-icon name="arrow-up-outline" class="application-greater-icon"></ion-icon>
                                    }
                                }
                                else
                                {
                                    <ion-icon name="add-outline" class="application-extra-icon"></ion-icon>
                                }

                            </li>
                        }
                    </ul>

                    @if (app.Status == "Accepted")
                    {
                        <p class="application-view-status">Application Accepted</p>
                    }
                    else
                    {
                        <form action="/JobApplication/AcceptApplication/@app.JobApplicationId/@ViewContext.RouteData.Values["postId"]" method="post">
                            <button type="submit" class="btn--form btn application-accept-btn"> Accept </button>
                        </form>
                    }
                }
                else
                {
                    <p class="applications-view-title">No skills listed.</p>
                }
            </div>
        }
    </div>
}
