@model Student_Job_Finder.Dtos.JobPostToAddDto

<h2>Add a Job Post</h2>

<form action="/JobPost/AddPost" method="post">
    <div class="form-group">
        <label for="PostTitle">Title</label>
        <input type="text" name="PostTitle" id="PostTitle" required />
    </div>

    <div class="form-group">
        <label for="PostContent">Content</label>
        <textarea name="PostContent" id="PostContent" rows="5" required></textarea>
    </div>

    <button type="submit">Add Post</button>
</form>
