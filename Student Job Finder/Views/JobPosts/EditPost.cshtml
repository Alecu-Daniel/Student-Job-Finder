@using Student_Job_Finder.Helpers
@model Student_Job_Finder.Models.JobSkillsViewModel

<div class="container edit-post-container">

    <h2 class="edit-post-view-title">Edit Job Post</h2>


    <h3 class="edit-post-skill-title">Required Skills</h3>

    @if (Model.PostSkills.Any())
    {
        <div class="edit-post-skills-container">


            <ul class="edit-post-skills-list">
                @foreach (var skill in Model.PostSkills)
                {
                    <li class="edit-post-skill">
                        <div class="edit-post-skill-info">
                            <p>@skill.SkillName</p>
                            <p class="@SkillHelper.SkillColorClass(skill.SkillScore)">@SkillHelper.SkillLevelName(skill.SkillScore)</p>
                        </div>

                        <form method="post"
                              action="/JobPost/DeleteJobSkill/@skill.JobSkillId" class="skill-delete-form">
                            <input type="hidden" name="postId" value="@Model.PostId" />
                            <button type="submit" class="edit-post-skill-delete-btn" title="Remove skill">
                                <ion-icon name="close-circle-outline" class="edit-post-skill-delete-icon"></ion-icon>
                            </button>
                        </form>
                    </li>
                }
            </ul>
        </div>
    }



    <form method="post" action="/JobPost/AddJobSkill">
        <input type="hidden" name="JobPostId" value="@Model.PostId" />

        <div class="edit-post-skills-select">

            <div class="edit-post-input-container">

                <label for="SkillName" class="edit-post-input-label">Skill</label>

                <select id="SkillName" name="SkillName" required class="edit-post-input">
                    @foreach (var skill in SkillHelper.allSkills)
                    {
                        <option value="@skill">
                            @skill
                        </option>
                    }
                </select>

            </div>

            <div class="edit-post-input-container">
                <label for="SkillLevel" class="edit-post-input-label">Required Level</label>
                <select id="SkillLevel" name="SkillLevel" required class="edit-post-input">
                    <option value="">--Select level--</option>
                    <option value="Beginner">Beginner</option>
                    <option value="Intermediate">Intermediate</option>
                    <option value="Advanced">Advanced</option>
                    <option value="Expert">Expert</option>
                </select>
            </div>

        </div>

        <button type="submit" class="btn btn--form edit-post-form-btn">Add Skill</button>
    </form>
 
        <form method="post" action="/JobPost/EditPost">
            <input type="hidden" name="PostId" value="@Model.PostId" />

            

            <div class="edit-post-input-container">
                <label for="PostTitle" class="edit-post-input-label">Title</label>
                <input type="text" id="PostTitle" name="PostTitle" value="@Model.PostTitle" required class="edit-post-input" />
            </div>


            <div class="edit-post-salary-container">
            
                <div class="edit-post-input-container">
                    <label class="edit-post-input-label">Salary</label>
                    <input type="number" step="0.01" name="Price" value=@Model.Price required class="edit-post-input" />
                </div>

                <div class="edit-post-input-container">
                    <label class="edit-post-input-label">Pay Period</label>
                    <select name="PricePeriod" required class="edit-post-input">
                        <option value="Hour" @(Model.PricePeriod == "Hour" ? "selected" : "")>Per hour</option>
                        <option value="Month" @(Model.PricePeriod == "Month" ? "selected" : "")>Per month</option>
                    </select>
                </div>

            </div>

                <div class="edit-post-input-container-content">
                    <label for="PostContent" class="edit-post-input-label">Content</label>
                    <textarea id="PostContent" name="PostContent" rows="6" required class="edit-post-content">@Model.PostContent</textarea>
                </div>

            <button type="submit" class="btn btn--form">Save Changes</button>
        </form>
        
</div>