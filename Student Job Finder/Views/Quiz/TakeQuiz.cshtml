@model Student_Job_Finder.Models.TakeQuizViewModel

<div class="container quiz-container">
    <h2 class="quiz-title">Skill Assessment</h2>
    <p class="quiz-subtitle">Please answer the following questions to complete your application.</p>

    <form method="post" action="/Quiz/SubmitQuiz">
        <input type="hidden" name="QuizId" value="@Model.QuizId" />

        @for (int i = 0; i < Model.Questions.Count; i++)
        {
            <div class="quiz-question-card">
                <p class="question-text"><strong>Q@(i + 1):</strong> @Model.Questions[i].QuestionText</p>

                <input type="hidden" name="Answers[@i].QuestionId" value="@Model.Questions[i].QuestionId" />

                <div class="quiz-options">
                    <label class="quiz-option">
                        <input type="radio" name="Answers[@i].StudentAnswer" value="A" required>
                        <span>A: @Model.Questions[i].OptionA</span>
                    </label>
                    <label class="quiz-option">
                        <input type="radio" name="Answers[@i].StudentAnswer" value="B">
                        <span>B: @Model.Questions[i].OptionB</span>
                    </label>
                    <label class="quiz-option">
                        <input type="radio" name="Answers[@i].StudentAnswer" value="C">
                        <span>C: @Model.Questions[i].OptionC</span>
                    </label>
                    <label class="quiz-option">
                        <input type="radio" name="Answers[@i].StudentAnswer" value="D">
                        <span>D: @Model.Questions[i].OptionD</span>
                    </label>
                </div>
            </div>
        }

        <button type="submit" class="btn btn--form quiz-submit-btn">Submit Quiz</button>
    </form>
</div>