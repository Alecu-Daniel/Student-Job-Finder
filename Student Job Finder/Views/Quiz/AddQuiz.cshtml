@model Student_Job_Finder.Models.JobSkillsViewModel
@using Student_Job_Finder.Helpers

<div class="container add-quiz-container margin-bottom-md">


    <h3 class="quiz-title">Quiz Questions</h3>

    <form method="post" action="/Quiz/AddQuestion">
        <div class="quiz-select">
            <input type="hidden" name="JobPostId" value="@Model.PostId" />

            <div class="add-quiz-input-container">
                <label for="SkillName" class="add-quiz-input-label">Skill to Test</label>
                <select id="SkillName" name="SkillName" required class="add-quiz-input">
                    @foreach (var skill in SkillHelper.allSkills)
                    {
                        <option value="@skill">@skill</option>
                    }
                </select>
            </div>

            <div class="input-container-quiz-content">
                <label for="QuestionText" class="add-quiz-input-label">Question Text</label>
                <textarea id="QuestionText" name="QuestionText" required class="quiz-content"></textarea>
            </div>

            <div class="add-quiz-input-container">
                <label for="OptionA" class="add-quiz-input-label">Option A</label>
                <input type="text" id="OptionA" name="OptionA" required class="add-quiz-input" />
            </div>
            <div class="add-quiz-input-container">
                <label for="OptionB" class="add-quiz-input-label">Option B</label>
                <input type="text" id="OptionB" name="OptionB" required class="add-quiz-input" />
            </div>
            <div class="add-quiz-input-container">
                <label for="OptionC" class="add-quiz-input-label">Option C</label>
                <input type="text" id="OptionC" name="OptionC" required class="add-quiz-input" />
            </div>
            <div class="add-quiz-input-container">
                <label for="OptionD" class="add-quiz-input-label">Option D</label>
                <input type="text" id="OptionD" name="OptionD" required class="add-quiz-input" />
            </div>

            <div class="add-quiz-input-container">
                <label for="CorrectOption" class="add-quiz-input-label">Correct Option</label>
                <select id="CorrectOption" name="CorrectOption" required class="add-quiz-input">
                    <option value="A">A</option>
                    <option value="B">B</option>
                    <option value="C">C</option>
                    <option value="D">D</option>
                </select>
            </div>
            <button type="submit" class="btn btn--form add-quiz-form-btn">Add Question</button>
        </div>
    </form>

</div>

@if (Model.ExistingQuestions.Any())
{
    <div class="add-quiz-list-container">
        @foreach (var question in Model.ExistingQuestions)
        {
            <div class="add-quiz-card">
                <div class="add-quiz-card-header">
                    <p class="add-quiz-skill-title">Skill: @question.SkillName</p>
                    <form method="post" action="/Quiz/DeleteQuestion/@question.QuestionId" class="add-quiz-delete-form">
                        <input type="hidden" name="postId" value="@Model.PostId" />
                        <button type="submit" class="add-quiz-delete-btn" title="Remove Question">
                            <ion-icon name="trash-outline" class="add-quiz-trash-icon"></ion-icon>
                        </button>
                    </form>
                </div>

                <p class="add-quiz-question-text">@question.QuestionText</p>

                <div class="add-quiz-options-grid">
                    <p><span>A:</span> @question.OptionA</p>
                    <p><span>B:</span> @question.OptionB</p>
                    <p><span>C:</span> @question.OptionC</p>
                    <p><span>D:</span> @question.OptionD</p>
                </div>

                <div class="add-quiz-card-footer">
                    <span>Correct Answer: <strong>@question.CorrectOption</strong></span>
                </div>
            </div>
        }
    </div>
}